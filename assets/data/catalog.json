  "ibareBooks": [
    {
      "id": "bina",
      "title": "Metnü'l-Binâ ve'l-Esâs",
      "assetPath": "assets/data/ibare/bina.json"
    }
  ],
  "lessons": [
    {
      "order": 1,
      "title": "Emsile-i Muhtelife",
      "summary": "Temel sarf formlarını ve anlamlarını birlikte gör.",
      "rule": "Aynı kökten türeyen farklı kalıplar anlam ilişkisiyle çalışılır.",
      "relatedCategory": "mazi"
    },
    {
      "order": 2,
      "title": "Fiil-i Mâzi",
      "summary": "Geçmiş zaman çekimlerini şahıslara göre incele.",
      "rule": "Mâzi fiil geçmişte gerçekleşen işi bildirir.",
      "relatedCategory": "mazi"
    },
    {
      "order": 3,
      "title": "Fiil-i Muzâri",
      "summary": "Şimdiki, geniş ve gelecek zaman anlamlarını tanı.",
      "rule": "Muzâri fiil başına muzaraat harflerinden biri gelerek kurulur.",
      "relatedCategory": "muzari"
    },
    {
      "order": 4,
      "title": "Malum ve Meçhul",
      "summary": "Etken ve edilgen çekim farkını karşılaştır.",
      "rule": "Meçhul çekimde hareke düzeni değişir ve işi yapan gizlenir.",
      "relatedCategory": "mazi"
    },
    {
      "order": 5,
      "title": "Masdarlar",
      "summary": "Masdar-ı Gayr-ı Mîmî, Bina-i Merre ve Bina-i Nev' kuralları.",
      "rule": "Masdarlar fiilin mastar (eylem) halini, yapılma sayısını veya tarzını bildirir.",
      "relatedCategory": "masdar"
    },
    {
      "order": 6,
      "title": "İsm-i Fâil ve İsm-i Mef'ûl",
      "summary": "Arapçada etken ve edilgen sıfat türetme kuralları.",
      "rule": "İsm-i Fâil işi yapanı (etken), İsm-i Mef'ûl ise işten etkileneni (edilgen) gösterir.",
      "relatedCategory": "ismFail"
    },
    {
      "order": 7,
      "title": "İsm-i Zaman/Mekân ve Âlet",
      "summary": "Zaman, mekan ve alet isimlerinin vezinleri.",
      "rule": "Fiilin gerçekleştiği zamanı, yeri ve gerçekleştirmek için kullanılan aleti ifade eder.",
      "relatedCategory": "ismZamanMekan"
    },
    {
      "order": 8,
      "title": "İsm-i Tasğir ve İsm-i Mensub",
      "summary": "Küçültme ismi ve aidiyet eki kuralları.",
      "rule": "İsm-i Tasğir küçültme/sevgi anlamı katarken, İsm-i Mensub aitlik/nispet bildirir.",
      "relatedCategory": "ismTasgir"
    },
    {
      "order": 9,
      "title": "İsm-i Tafdil ve Mübalağa",
      "summary": "Karşılaştırma sıfatları ve abartılı sıfat formları.",
      "rule": "İsm-i Tafdil en/daha anlamı katarken, Mübalağa İsm-i Fâil fiilin çokça yapıldığını belirtir.",
      "relatedCategory": "ismTafdil"
    }
  ],
